  "keyFeatures": [
    "Multi-instance browser orchestration",
    "HTTP API and CLI interfaces",
    "Token-efficient text extraction (800 tokens/page)",
    "Persistent profiles with session management",
    "Advanced stealth mode and fingerprint rotation",
    "Real-time dashboard with live monitoring",
    "Headless and headed browser modes",
    "Chrome DevTools Protocol integration",
    "WebSocket screencast streaming",
    "Docker and npm distribution"
  ],
  "publicApiSurface": [
    "POST /instances/launch - Create new browser instance",
    "GET /instances - List all instances",
    "GET /instances/{id} - Get instance details",
    "DELETE /instances/{id} - Stop instance",
    "POST /instances/{id}/tabs/open - Open new tab",
    "GET /tabs/{id}/snapshot - Get accessibility tree",
    "POST /tabs/{id}/navigate - Navigate to URL",
    "POST /tabs/{id}/action - Execute user action (click, type, etc.)",
    "GET /tabs/{id}/text - Extract page text",
    "GET /tabs/{id}/screenshot - Capture screenshot",
    "POST /tabs/{id}/evaluate - Execute JavaScript",
    "GET /profiles - List browser profiles",
    "POST /profiles - Create new profile",
    "GET /tabs/{id}/cookies - Get cookies",
    "GET /metrics - Get instance metrics",
    "pinchtab - Start orchestrator server",
    "pinchtab instance launch - CLI: Launch instance",
    "pinchtab profile create - CLI: Create profile",
    "pinchtab nav <url> - CLI: Navigate browser",
    "pinchtab snap - CLI: Take snapshot",
    "pinchtab click <ref> - CLI: Click element"
  ]
