{
  "$schema": "https://mintlify.com/docs.json",
  "name": "PinchTab",
  "theme": "aspen",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/pinchtab/pinchtab"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pinchtab/pinchtab"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Installation",
            "pages": [
              "installation/install",
              "installation/docker",
              "installation/npm",
              "installation/build-from-source"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/instances",
              "features/profiles",
              "features/tabs",
              "features/dashboard",
              "features/stealth-mode",
              "features/headless-vs-headed"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/multi-instance",
              "guides/ai-agent-integration",
              "guides/common-patterns",
              "guides/memory-monitoring",
              "guides/docker-deployment"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/architecture",
              "advanced/cdp-integration",
              "advanced/configuration",
              "advanced/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api/overview",
              "api/authentication"
            ]
          },
          {
            "group": "Core APIs",
            "pages": [
              "api/instances",
              "api/profiles",
              "api/tabs"
            ]
          },
          {
            "group": "Browser Operations",
            "pages": [
              "api/navigation",
              "api/actions",
              "api/snapshot",
              "api/evaluation"
            ]
          },
          {
            "group": "Media & Export",
            "pages": [
              "api/screenshots",
              "api/pdf",
              "api/screencast"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "api/cookies",
              "api/stealth",
              "api/metrics",
              "api/downloads"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "cli/overview",
              "cli/configuration"
            ]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/server",
              "cli/instance",
              "cli/profile",
              "cli/tab",
              "cli/navigate",
              "cli/action",
              "cli/snapshot"
            ]
          }
        ]
      }
    ]
  }
}
